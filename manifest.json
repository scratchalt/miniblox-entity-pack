{
  "manifest_version": 3,
  "name": "Miniblox Texture Swapper",
  "version": "1.0",
  "description": "Redirects Miniblox assets to custom textures",
  
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],

  "host_permissions": [
    "*://miniblox.io/*",
    "*://*.miniblox.io/*"
  ],

  "background": {
    "service_worker": "background.js"
  }
}
