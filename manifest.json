{
"update_url": "https://clients2.google.com/service/update2/crx",

  "manifest_version": 3,
  "name": "Entity Texture Pack",
  "version": "1.6",
  "description": "Swaps textures on nearly every mob (entity)!",
  "author": ["mochi_iris", "TheM1ddleM1n"],
  "background": {"service_worker": "background.js"},
  "icons": {
    "128": "icon.png"
  },
  "permissions": [
   "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "https://miniblox.io/*",
    "https://raw.githubusercontent.com/*"
  ]
}
